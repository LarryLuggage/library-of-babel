# Browser-safe Supabase connection details.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase key for privileged seed ingestion.
# SUPABASE_SERVICE_ROLE_KEY is supported as a legacy fallback.
SUPABASE_SECRET_KEY=

# Bearer token required by POST /api/books/seed.
BOOK_SEED_TOKEN=
